---
layout: base.njk
pagination:
  data: collections.categories
  size: 1
  alias: cat
permalink: "/topics/{{ cat.slug }}/index.html"
eleventyComputed:
  title: "{{ cat.name }}"
  description: "Munder Difflin blog posts on {{ cat.name }} — agentic coding with Claude Code, the hive, GOD orchestrator, and long-term memory."
  seoTitle: "{{ cat.name }} — Munder Difflin Blog"
  canonicalUrl: "{{ site.origin }}/blog/topics/{{ cat.slug }}/"
---
{% block content %}
<header class="page-head wrap">
  <nav class="crumbs" aria-label="Breadcrumb" style="font-family:var(--font-mono);font-size:12px;color:var(--ink-faint);display:flex;gap:8px;">
    <a href="{{ '/' | u }}" style="color:var(--ink-dim)">Blog</a><span>/</span>
    <a href="{{ '/topics/' | u }}" style="color:var(--ink-dim)">Topics</a>
  </nav>
  <p class="eyebrow">Topic</p>
  <h1>{{ cat.name }}</h1>
  <p class="lead">{{ cat.posts.length }} post{{ "s" if cat.posts.length != 1 }} in this cluster.</p>

  <div class="filters" role="navigation" aria-label="Topics">
    <a class="chip" href="{{ '/' | u }}">All</a>
    {% for c in collections.categories %}
    <a class="chip" href="{{ ('/topics/' + c.slug + '/') | u }}"{% if c.slug == cat.slug %} aria-current="page"{% endif %}>{{ c.name }}<span class="ct">{{ c.posts.length }}</span></a>
    {% endfor %}
  </div>
</header>

<section class="wrap">
  <div class="post-grid">
    {% for p in cat.posts %}{% include "card.njk" %}{% endfor %}
  </div>
</section>
{% endblock %}
