{% extends "base.njk" %}
{% block content %}
<header class="page-head wrap">
  {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
  <h1>{{ heading or title }}</h1>
  {% if lead %}<p class="lead">{{ lead | safe }}</p>{% endif %}
</header>
<div class="wrap" style="padding-bottom:48px">
  <div class="prose">
    {{ content | safe }}
  </div>
</div>
{% endblock %}
