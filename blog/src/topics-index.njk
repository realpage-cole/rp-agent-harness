---
layout: base.njk
title: Topics
description: "Browse the Munder Difflin blog by topic cluster — guides, engineering deep-dives, agentic-coding notes, and product dispatches."
seoTitle: "Topics — Munder Difflin Blog"
permalink: /topics/index.html
---
{% block content %}
<header class="page-head wrap">
  <p class="eyebrow">Browse by cluster</p>
  <h1>Topics</h1>
  <p class="lead">Everything we write, grouped into clusters. Technical guides and engineering
  deep-dives on the left; the human side of running an agent office on the right.</p>
</header>

<section class="wrap">
  <div class="post-grid">
    {% for c in collections.categories %}
    <a class="card" href="{{ ('/topics/' + c.slug + '/') | u }}" style="text-decoration:none">
      <span class="thumb t-{{ c.slug }}" aria-hidden="true">{{ c.name | upper }}</span>
      <div class="body">
        <h3 style="color:var(--ink)">{{ c.name }}</h3>
        <p class="dek">{{ c.posts.length }} post{{ "s" if c.posts.length != 1 }}.</p>
        <div class="foot"><span class="more">View topic →</span></div>
      </div>
    </a>
    {% endfor %}
  </div>

  {% if collections.tagList.length %}
  <div class="filters" style="padding-top:36px">
    <span class="eyebrow" style="align-self:center">Tags</span>
    {% for t in collections.tagList %}
    <a class="chip" href="{{ ('/tags/' + t.slug + '/') | u }}">{{ t.name }}<span class="ct">{{ t.count }}</span></a>
    {% endfor %}
  </div>
  {% endif %}
</section>
{% endblock %}
